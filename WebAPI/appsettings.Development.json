{
	//Danh sách các máy chủ (hosts) được phép truy cập ứng dụng
	//Ví dụ: abc.online;www.abc.online;admin.abc.online;www.admin.abc.online
	//Nếu đang lập trình thì nên gõ là dấu *
	"AllowedHosts": "*",
	//Cấu hình CORS (Cross-Origin Resource Sharing)
	"Cors": {
		"AllowedOrigins": "http://localhost:5173;http://localhost:3000;http://localhost:8081"
	},
	//Chuỗi kết nối cơ sở dữ liệu
	"ConnectionStrings": {
		"StringConnection": "Server=DESKTOP-HAIDVQD\\SQLEXPRESS;Database=AnhEmMotorDB;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
	},
	//Cấu hình xem môi trường cơ sở dữ liệu chạy là MS SQL Server ("SqlServer") hoặc MySQL ("MySql") hoặc PostgreSql ("PostgreSql")
	"Provider": "SqlServer",
	//Tên miền xuất cookie (Domain). Trống: localhost, có giá trị: sử dụng domain đó.
